{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-mkdir",
    "fs:allow-read-dir",
    "fs:allow-app-data-write",
    "fs:allow-app-data-read",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-message",
    "sql:default"
  ]
}